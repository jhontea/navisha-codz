# Dockerfile for Code Runner Sandbox
# This image executes user-submitted Go code in an isolated environment.
# Build: docker build -f runner/Dockerfile.runner -t coding-challenge-runner:latest .

FROM golang:1.21-alpine

# Create a non-root user for running code
RUN adduser -D -u 1000 runner

# Set up a minimal workspace
WORKDIR /app
RUN chown runner:runner /app

# Switch to non-root user
USER runner

# Default entrypoint - the binary is mounted at runtime
ENTRYPOINT ["/app/sandbox"]
