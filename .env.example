# ============================================
# Coding Challenge Platform - Environment
# ============================================

# ============================================
# Server Configuration
# ============================================
PORT=8080
LOG_LEVEL=debug  # debug, info, warn, error

# ============================================
# Database (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=coding_challange
DB_MAX_CONNS=25
DB_IDLE_CONNS=5

# ============================================
# Redis
# ============================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# ============================================
# RabbitMQ
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ============================================
# JWT Authentication (WAJIB DIISI!)
# ============================================
# Generate dengan: openssl rand -base64 32
# Jangan pernah menggunakan default ini di production!
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_TTL_MIN=15        # Access token expiry (minutes)
JWT_REFRESH_TTL_HOURS=168    # Refresh token expiry (hours = 7 days)

# ============================================
# Code Execution
# ============================================
SANDBOX_IMAGE=golang:1.21-alpine
SANDBOX_MEMORY_MB=256
SANDBOX_TIME_SEC=10
DISABLE_LOCAL_FALLBACK=false
MAX_OUTPUT_SIZE_MB=1
MAX_CODE_SIZE_KB=64

# ============================================
# Problem Loader
# ============================================
PROBLEMS_DIR=./problems

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
SUBMIT_RATE_LIMIT=10
SUBMIT_RATE_WINDOW_SECONDS=60

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:9100
VITE_WS_URL=ws://localhost:9107
